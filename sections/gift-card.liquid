{{ 'gift-registry.css' | asset_url | stylesheet_tag }}

<section class="gift-registry">

  <div class="page-width">

    <div class="gift-registry__content">

      <div class="gift-registry__text">

        {% if section.settings.badge != blank %}
          <span class="gift-registry__badge">
            {{ section.settings.badge }}
          </span>
        {% endif %}

        <h2>{{ section.settings.heading }}</h2>

        <div class="gift-registry__description">
          {{ section.settings.description }}
        </div>

        <ul class="gift-registry__features">

          {% for block in section.blocks %}

            {% if block.type == 'feature' %}

              <li>
                ✓ {{ block.settings.text }}
              </li>

            {% endif %}

          {% endfor %}

        </ul>

        <button
          class="button button--primary"
          id="openRegistryModal">

          {{ section.settings.button_label }}

        </button>

      </div>

      <div class="gift-registry__image">

        {% if section.settings.image %}

          {{
            section.settings.image
            | image_url: width:900
            | image_tag
          }}

        {% endif %}

      </div>

    </div>

  </div>

</section>

<div id="registry-modal" class="registry-modal">

  <div class="registry-modal__content">

    <button class="registry-modal__close">
      ×
    </button>

    <h3>Create Your Registry</h3>

    <form id="registry-form">

      <label>Name</label>

      <input
        type="text"
        name="name"
        required>

      <label>Email</label>

      <input
        type="email"
        name="email"
        required>

      <label>Photo (optional)</label>

      <input
        type="file"
        name="photo">

      <label>Registry Type</label>

      <select name="occasion">

        <option>Birthday</option>

        <option>Christmas</option>

        <option>Wedding</option>

        <option>Baby Shower</option>

        <option>Graduation</option>

        <option>Custom</option>

      </select>

      <label>Registry Title</label>

      <input
        type="text"
        name="title">

      <label>Description</label>

      <textarea
        name="description"></textarea>

      <button
        class="button button--primary">

        Create Registry

      </button>

    </form>

  </div>

</div>

<script>

document.querySelector('#openRegistryModal')
?.addEventListener('click', () => {

    document
      .querySelector('#registry-modal')
      .classList.add('active')

})

document.querySelector('.registry-modal__close')
?.addEventListener('click', () => {

    document
      .querySelector('#registry-modal')
      .classList.remove('active')

})

document
.querySelector('#registry-form')
?.addEventListener('submit', async(e)=>{

    e.preventDefault()

    const form = new FormData(e.target)

    const response = await fetch(
      "https://YOUR-APP/create-registry",
      {
        method:"POST",
        body:form
      }
    )

    const registry = await response.json()

    window.location.href = registry.url

})

</script>

{% schema %}
{
  "name": "Gift Registry",

  "settings":[

    {
      "type":"text",
      "id":"badge",
      "label":"Badge",
      "default":"NEW"
    },

    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Create a Gift Registry"
    },

    {
      "type":"richtext",
      "id":"description",
      "label":"Description",
      "default":"<p>Create your own birthday, Christmas or wedding registry and let friends contribute toward the gifts you really want.</p>"
    },

    {
      "type":"text",
      "id":"button_label",
      "label":"Button Label",
      "default":"Start Your Registry"
    },

    {
      "type":"image_picker",
      "id":"image",
      "label":"Image"
    }

  ],

  "blocks":[

    {
      "type":"feature",
      "name":"Feature",

      "settings":[

        {
          "type":"text",
          "id":"text",
          "label":"Feature"
        }

      ]

    }

  ],

  "presets":[

    {
      "name":"Gift Registry",

      "blocks":[

        {
          "type":"feature",
          "settings":{
            "text":"Create your own personalised registry"
          }
        },

        {
          "type":"feature",
          "settings":{
            "text":"Share a unique link with friends and family"
          }
        },

        {
          "type":"feature",
          "settings":{
            "text":"Track contributions in real time"
          }
        },

        {
          "type":"feature",
          "settings":{
            "text":"Fund premium ride-on toys together"
          }
        }

      ]

    }

  ]

}
{% endschema %}